# =============================================================
# The Alchemille — env template
# Copy this file to .env.local and fill in real values.
# Never commit .env.local.
# =============================================================

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Clerk (https://dashboard.clerk.com) ---
# Create application → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# Webhook secret: Clerk dashboard → Webhooks → add endpoint at
# <app-url>/api/webhooks/clerk, events user.created/updated/deleted
CLERK_WEBHOOK_SECRET="whsec_xxx"

# Where Clerk sends users after auth (these match the catch-all routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding"

# --- Supabase (https://supabase.com/dashboard) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# SERVER ONLY. Bypasses RLS — never expose client-side.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# --- Resend (https://resend.com) ---
# Used for milestone email notifications (no push notifs in v1)
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="hello@thealchemille.com"
